/**
 * 文件名：version.h.in
 * 职责：CMake configure_file 模板 —— 由 CMake 在配置阶段替换为实际版本号
 *
 * 这是一个 模板文件（.in 后缀），CMake 的 configure_file() 命令会读取它，
 * 把其中的 @变量名@ 替换为 CMake 变量的实际值，然后输出到指定路径。
 *
 * 例如：
 *   模板中写：@BitPerfect_VERSION_MAJOR@
 *   CMake 替换为：1
 *
 * 生成目标路径：build/debug/src/version.h（被 include 到 main.cpp 中）
 *
 * 用法：
 *   #include "version.h"         // 在所有需要版本号的源文件中包含此头文件
 *   BITPERFECT_VERSION_MAJOR     // 主版本号（如 1）
 *   BITPERFECT_VERSION_STRING    // 完整版本字符串（如 "1.0.0"）
 *
 * 所属模块：src（项目级）
 */

#pragma once                        // 防止重复包含（等价于传统的 #ifndef #define #endif）

// 以下 @变量@ 是 CMake 的占位符，在 cmake configure 阶段会被自动替换
// 变量的值来自根 CMakeLists.txt 中 project(VERSION 1.0.0) 的定义

#define BITPERFECT_VERSION_MAJOR @BitPerfect_VERSION_MAJOR@   // 主版本号（不兼容的 API 变更时递增）
#define BITPERFECT_VERSION_MINOR @BitPerfect_VERSION_MINOR@   // 次版本号（向后兼容的功能新增时递增）
#define BITPERFECT_VERSION_PATCH @BitPerfect_VERSION_PATCH@   // 修订版本号（向后兼容的 bug 修复时递增）
#define BITPERFECT_VERSION_STRING "@BitPerfect_VERSION@"      // 完整版本号字符串，如 "1.0.0"
