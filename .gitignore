# ============================================
# BitPerfect 项目 .gitignore
# ============================================
# Git 会根据本文件中的规则忽略匹配的文件和目录，
# 被忽略的内容不会被 git add 添加，也不会被提交到仓库。

# ============================================
# 1. 项目文档（个人学习用，不纳入版本管理）
# ============================================
# 学习手册是开发者个人学习资料，不需要上传到开源仓库
项目规划/学习手册/
# 技术选型参考对比文档是过程产物，最终决策已记录在最终技术选型决策.md 中
项目规划/技术选型参考对比/
# 项目参考手册是个人参考资料，不需要上传到开源仓库
项目规划/项目参考手册/
# 临时文件是开发过程中的临时产物，不需要上传到开源仓库
项目规划/临时文件/

# ============================================
# 2. 编译产物
# ============================================
# CMake 构建输出目录（包含生成的 Makefile、中间文件、可执行文件）
build/
# 编译中间文件
*.o
*.obj
# macOS 应用包
*.app
# Windows 可执行文件
*.exe
# 静态库
*.a
*.lib
# 动态库
*.dylib
*.so
*.dll

# ============================================
# 3. IDE 和编辑器配置（各人偏好不同，不应提交）
# ============================================
# VS Code 工作区配置
.vscode/
# CLion 工程配置
.idea/
# Xcode 工程（由 CMake 自动生成，不需要提交）
*.xcodeproj
*.xcworkspace
# Xcode 用户数据
xcuserdata/

# ============================================
# 4. 日志文件（运行时生成）
# ============================================
# 日志输出目录
logs/
# 日志文件
*.log

# ============================================
# 5. 数据库文件（运行时生成，每台电脑不同）
# ============================================
# SQLite 数据库主文件
*.db
# SQLite WAL 模式产生的辅助文件
*.db-wal
*.db-shm

# ============================================
# 6. macOS 系统文件
# ============================================
# Finder 文件夹元信息（包含图标位置、窗口大小等，不具可移植性）
.DS_Store
# 苹果双格式文件（AppleDouble）
.AppleDouble
# 资源 fork 隐藏文件
._*
# Spotlight 索引（可能产生于挂载的外部磁盘）
.Spotlight-V100
# 废纸篓
.Trashes

# ============================================
# 7. 临时文件和备份
# ============================================
# 通用临时文件
*.tmp
*.temp
# Vim 交换文件
*.swp
# 编辑器自动备份
*~
# 以 # 开头结尾的临时文件
\#*\#
# Emacs 备份
.\#*

# ============================================
# 8. 配置文件（运行时生成的本地配置）
# ============================================
# 应用运行时生成的配置文件（不同于源码中的 config.json 模板）
# 如果有本地测试用的配置文件，取消下面一行的注释
# config.local.json
